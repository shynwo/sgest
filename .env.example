SGEST_SECRET_KEY=replace-with-long-random-secret
SGEST_ADMIN_USER=admin
# Option 1 (recommended): hashed password
SGEST_ADMIN_PASSWORD_HASH=replace-with-werkzeug-hash
# Option 2 (fallback only): plain password
# SGEST_ADMIN_PASSWORD=change-me-now

# Cookies
SGEST_COOKIE_SECURE=1

# Optional host allowlist (comma separated, no protocol)
# SGEST_ALLOWED_HOSTS=stock.example.com,192.168.1.10

# Webhooks security (recommended ON)
SGEST_REQUIRE_WEBHOOK_TOKEN=1
SGEST_WEBHOOK_TOKEN=replace-with-random-webhook-token
# Optional per-source token overrides:
# SGEST_ETSY_WEBHOOK_TOKEN=replace
# SGEST_VINTED_WEBHOOK_TOKEN=replace
